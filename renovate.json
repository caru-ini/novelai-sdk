{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "prConcurrentLimit": 10,
  "prHourlyLimit": 0,
  "packageRules": [
    {
      "description": "Force chore(deps): prefix for all updates (override config:recommended's fix type)",
      "matchPackageNames": ["*"],
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    },
    {
      "description": "Disable major updates across all ecosystems",
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Automerge minor and patch updates",
      "matchUpdateTypes": ["minor", "patch", "digest", "pin"],
      "automerge": true
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true
  },
  "lockFileMaintenance": {
    "enabled": true
  }
}
